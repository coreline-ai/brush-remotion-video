node_modules/
output/
__pycache__/
.venv*/
.DS_Store
*.tsbuildinfo

# 공식 페이지에서 직접 받은 BGM 원본과 라이선스 증빙(재배포/커밋 금지)
local-assets/

# build.py가 생성하는 프로젝트 산출물은 커밋하지 않는다 (골든/공용 에셋만 추적)
data/*
!data/golden-single/
!data/golden-multi/
!data/golden-widgets/
!data/golden-single-widgets/
!data/pipeline-smoke/
# pipeline-smoke 실행 시 생성되는 QA 캡처·콘택트시트·프레임은 재생성 가능하므로 추적하지 않음
data/pipeline-smoke/qa/
# city-watercolor-600s 는 구 시스템 변환 레퍼런스 props.json 만 추적 (렌더 로그·QA 캡처·중간산출 제외)
!data/city-watercolor-600s/
data/city-watercolor-600s/*
!data/city-watercolor-600s/props.json
public/*
# brush-draw 는 붓/펜 커서 에셋만 추적 (자가점검 스크래치 제외)
!public/brush-draw/
public/brush-draw/*
!public/brush-draw/brush.png
!public/brush-draw/pen.svg

# 공개 테스트/데모 fixture는 필요한 파일만 추적하고, 같은 디렉터리의 새 생성물은 무시
!public/winter-snow-pine-demo/
public/winter-snow-pine-demo/*
!public/winter-snow-pine-demo/composed.png
!public/winter-snow-pine-demo/empty.routes.json
!public/winter-snow-pine-demo/routes.json
!public/winter-fullcanvas/
public/winter-fullcanvas/*
!public/winter-fullcanvas/bg.png
!public/winter-fullcanvas/content.png
!public/winter-fullcanvas/routes.json
!public/golden-multi/
public/golden-multi/*
!public/golden-multi/audio.wav
!public/pipeline-smoke/
public/pipeline-smoke/*
!public/pipeline-smoke/routes.json

# 작업 스크래치·중간 산출·분석 (전부 재생성 가능 — 커밋하지 않음)
tmp/
validation/
analysis/
.pytest_cache/

# 프로젝트 생성 워크스페이스 (output/ 처럼 산출물 — 커밋하지 않음)
projects/

# 외부 imagegen 결과를 가리키는 생성형 프로젝트 설정·소스 매니페스트 (로컬 작업 산출물)
examples/generated/

# examples 는 project.yaml·입력파일(txt/srt/mp3)만 추적한다.
# 생성된 배경/잉크/QA/콘택트시트 등 대용량 이미지는 무시 (기존 커밋 관행 = 설정만 추적)
examples/**/*.png
examples/**/*.jpg
examples/**/*.jpeg

# assets: 코드가 소비하는 카탈로그/스키마/매니페스트(JSON)를 추적한다.
# 대용량 원본 이미지는 재생성 가능하므로 무시한다. 음성 미리듣기 10종은
# 공개 청취 페이지와 voice-assets validate의 필수 fixture라 함께 추적한다.
assets/storybook/**/*.png
assets/storybook/**/*.jpg

# Storybook 에셋 검수 결과는 재생성 가능한 보고서이며, 공개 매니페스트와 분리해 추적하지 않음
assets/storybook/**/qa-report.md
assets/storybook/**/qa-metrics.json
